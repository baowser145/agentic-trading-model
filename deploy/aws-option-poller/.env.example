# Copy to .env on the server (never commit real secrets).

# --- Twilio SMS (recommended for text alerts) ---
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# ALERT_PHONE=+1XXXXXXXXXX

# --- Discord (works today if you reuse Sharp bot) ---
# DISCORD_TOKEN=...
# DISCORD_ALERT_CHANNEL_ID=...   # or ALLOWED_CHANNEL_ID
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Paths (defaults match systemd unit)
# WATCH_FILE=/home/ubuntu/agentic-option-poller/watch.json
# STATE_DIR=/home/ubuntu/agentic-option-poller/state
